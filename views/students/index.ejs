<!DOCTYPE html>
<html>
<head>

<title>Student Management System</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-5">

<h1 class="text-center mb-4">Student Management System</h1>

<h2>Add New Student</h2>

<form action="/students" method="POST" class="mb-4">

<div class="row">

<div class="col">
<input type="text" name="name" class="form-control" placeholder="Student Name" required>
</div>

<div class="col">
<input type="number" name="roll" class="form-control" placeholder="Roll Number" required>
</div>

<div class="col">
<button type="submit" class="btn btn-success">Add Student</button>
</div>

</div>

</form>

<h2>Students List</h2>

<table class="table table-bordered table-striped">

<thead class="table-dark">
<tr>
<th>Name</th>
<th>Roll</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% students.forEach(student => { %>

<tr>

<td><%= student.name %></td>

<td><%= student.roll %></td>

<td>

<a href="/view/students/<%= student._id %>/edit" class="btn btn-warning btn-sm">Edit</a>

<form action="/students/<%= student._id %>?_method=DELETE" method="POST" style="display:inline;">

<button type="submit" class="btn btn-danger btn-sm">Delete</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</body>
</html>